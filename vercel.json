{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/create-wallet",
      "destination": "/api/create-wallet.js"
    },
    {
      "source": "/api/wallet-balance",
      "destination": "/api/wallet-balance.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
