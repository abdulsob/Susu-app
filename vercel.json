{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/create-wallet",
      "dest": "/api/create-wallet.js"
    },
    {
      "src": "/api/wallet-balance",
      "dest": "/api/wallet-balance.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
